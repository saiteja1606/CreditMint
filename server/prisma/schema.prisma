generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum InterestType {
  SIMPLE
  MONTHLY
}

enum LoanStatus {
  PENDING
  PAID
  OVERDUE
}

enum NotificationType {
  DUE_TOMORROW
  DUE_TODAY
  OVERDUE
  PAYMENT_RECEIVED
  LOAN_CREATED
}

enum ReminderLogType {
  EMAIL
  IN_APP
}

enum ReminderLogStatus {
  SENT
  FAILED
  DISABLED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id                  String         @id @default(uuid())
  name                String
  email               String         @unique
  password            String
  phone               String?
  // SMTP overrides per user (optional)
  smtpHost            String?
  smtpPort            Int?
  smtpUser            String?
  smtpPass            String?
  smtpFrom            String?
  // Reminder preferences
  reminderDaysBefore  Int            @default(1)
  reminderEnabled     Boolean        @default(true)
  // Wallet / Capital Management
  initialBalance      Float          @default(0) @map("initial_balance")
  walletBalance       Float          @default(0) @map("wallet_balance")
  totalProfit         Float          @default(0) @map("total_profit")
  lentOutAmount       Float          @default(0) @map("lent_out_amount")

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  borrowers     Borrower[]
  loans         Loan[]
  notifications Notification[]
  walletTransactions WalletTransaction[]
}

model WalletTransaction {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  loanId        String?  @map("loan_id")
  type          String   // CREDIT, DEBIT
  source        String   // LOAN_CREATION, REPAYMENT, INTEREST_COLLECTION, MANUAL_ADJUSTMENT
  amount        Float
  balanceAfter  Float    @map("balance_after")
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  loan Loan? @relation(fields: [loanId], references: [id], onDelete: SetNull)
}

model Borrower {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  loans Loan[]
}

model Loan {
  id              String       @id @default(uuid())
  userId          String
  borrowerId      String
  amount          Float        // principal
  interestRate    Float        @default(0)   // flat % for simple or % per month for monthly
  interestType    InterestType @default(SIMPLE)
  totalInterest   Float        @default(0)
  totalAmount     Float        // amount + totalInterest
  paidAmount      Float        @default(0)
  startDate       DateTime
  dueDate         DateTime
  status          LoanStatus   @default(PENDING)
  notes           String?      @db.Text
  reminderEnabled Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrower     Borrower      @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  payments     Payment[]
  reminderLogs ReminderLog[]
  notifications Notification[]
  walletTransactions WalletTransaction[]
}

model Payment {
  id      String   @id @default(uuid())
  loanId  String
  amount  Float
  note    String?
  paidAt  DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  loanId    String?
  type      NotificationType
  message   String           @db.Text
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  loan Loan? @relation(fields: [loanId], references: [id], onDelete: SetNull)
}

model ReminderLog {
  id     String            @id @default(uuid())
  loanId String
  type   ReminderLogType
  status ReminderLogStatus
  sentAt DateTime          @default(now())
  error  String?           @db.Text

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
}
